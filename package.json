{
  "name": "pond-patrol-wallpaper",
  "version": "1.0.0",
  "description": "Original retro target-shooter web wallpaper for Wallpaper Engine.",
  "main": "index.js",
  "scripts": {
    "assets:original": "node scripts/generate-original-assets.mjs",
    "start": "cross-env NODE_OPTIONS=--openssl-legacy-provider webpack-dev-server --config config/webpack.config.js --host 127.0.0.1",
    "build": "cross-env NODE_OPTIONS=--openssl-legacy-provider webpack --config config/webpack.config.prod.js",
    "prod": "npm run build",
    "package:wallpaper": "npm run build && npm run verify:bundle && node scripts/package-wallpaper.mjs",
    "serve:wallpaper": "node scripts/serve-wallpaper.mjs build 5057",
    "verify:all": "node scripts/verify-all.mjs",
    "verify:bundle": "node scripts/verify-bundle.mjs",
    "verify:release": "npm run verify:all && npm run package:wallpaper",
    "verify:wallpaper": "node scripts/verify-wallpaper.mjs",
    "verify:wallpaper:matrix": "npm run verify:wallpaper && cross-env CHROME_WINDOW_SIZE=1920,1080 npm run verify:wallpaper && cross-env CHROME_WINDOW_SIZE=2560,1080 npm run verify:wallpaper"
  },
  "keywords": [
    "wallpaper-engine",
    "html5-canvas",
    "retro-game",
    "web-wallpaper"
  ],
  "author": "FluffyBacon678",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FluffyBacon678/DuckHunt-Wallpaper.git"
  },
  "bugs": {
    "url": "https://github.com/FluffyBacon678/DuckHunt-Wallpaper/issues"
  },
  "homepage": "https://github.com/FluffyBacon678/DuckHunt-Wallpaper#readme",
  "license": "ISC",
  "browserslist": "> 0.3%, not IE 11",
  "devDependencies": {
    "@babel/core": "^7.11.6",
    "@babel/plugin-proposal-class-properties": "^7.10.4",
    "@babel/preset-env": "^7.11.5",
    "archiver": "^8.0.0",
    "autoprefixer": "^9.6.1",
    "babel-loader": "^8.1.0",
    "clean-webpack-plugin": "^3.0.0",
    "copy-webpack-plugin": "^6.1.1",
    "cross-env": "^7.0.3",
    "css-loader": "^4.3.0",
    "file-loader": "^6.1.0",
    "html-webpack-plugin": "^4.5.0",
    "mini-css-extract-plugin": "^0.8.0",
    "postcss-loader": "^3.0.0",
    "raw-loader": "^4.0.1",
    "sass": "^1.69.7",
    "sass-loader": "^10.0.2",
    "webpack": "^4.44.2",
    "webpack-cli": "^3.3.12",
    "webpack-dev-server": "^3.11.0"
  },
  "dependencies": {
    "@babel/polyfill": "^7.11.5",
    "@fontsource/press-start-2p": "^5.0.18",
    "@fontsource/teko": "^5.0.18"
  }
}
